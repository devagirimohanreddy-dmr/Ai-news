# =============================================================================
# AI News Aggregator Bot — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL via asyncpg)
# For Docker: use service name "postgres" instead of "localhost"
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ainews

# ---------------------------------------------------------------------------
# Postgres credentials (used by docker-compose)
# ---------------------------------------------------------------------------
POSTGRES_DB=ainews
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Redis (Celery broker + LLM response cache)
# For Docker: use service name "redis" instead of "localhost"
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# LLM API Keys (at least one is recommended; Ollama works without a key)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Local LLM — Ollama
# ---------------------------------------------------------------------------
# For Docker: use service name "ollama" instead of "localhost"
OLLAMA_BASE_URL=http://ollama:11434

# ---------------------------------------------------------------------------
# Web Scraping — Firecrawl
# ---------------------------------------------------------------------------
# For Docker: use service name "firecrawl" instead of "localhost"
FIRECRAWL_BASE_URL=http://firecrawl:3002

# ---------------------------------------------------------------------------
# Social Media / News APIs
# ---------------------------------------------------------------------------
# Twitter API v2 bearer token (https://developer.twitter.com)
TWITTER_BEARER_TOKEN=
# NewsAPI.org API key (https://newsapi.org/register)
NEWSAPI_KEY=

# ---------------------------------------------------------------------------
# Azure Bot Service (Microsoft Teams integration)
# ---------------------------------------------------------------------------
AZURE_BOT_APP_ID=
AZURE_BOT_APP_PASSWORD=
TEAMS_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------
# Daily digest delivery time (UTC, 24-hour format)
DIGEST_SCHEDULE_HOUR=8
DIGEST_SCHEDULE_MINUTE=0

# ---------------------------------------------------------------------------
# Thresholds
# ---------------------------------------------------------------------------
# Articles scoring >= this value trigger a breaking-news alert
BREAKING_NEWS_THRESHOLD=8

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_PORT=8080
